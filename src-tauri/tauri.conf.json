{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "elite-lucky-draw",
  "version": "0.1.1",
  "identifier": "com.elite.luckydraw",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Elite Lucky Draw - Navigation Dashboard",
        "label": "operator",
        "url": "index.html",
        "width": 1000,
        "height": 750,
        "resizable": true
      },
      {
        "title": "Lucky Draw - Main Screen",
        "label": "main-screen",
        "url": "lucky-draw.html",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}